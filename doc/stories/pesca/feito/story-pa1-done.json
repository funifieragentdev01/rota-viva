      "dialogues": [
        {
          "character_id": "pa1_c2",
          "text": "Deixa eu mostrar o que está em jogo. O defeso dura três meses. O seguro paga um salário mínimo por mês.",
          "position": 0,
          "_ttsGenerating": false,
