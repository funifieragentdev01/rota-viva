      "dialogues": [
        {
          "text": "Três semanas antes do defeso, Lucas chega com uma mensagem da colônia no celular.",
          "position": 0,
          "_ttsGenerating": false,
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d4de6650e26dad215b2/story_audio/69eaea6fb5fee93883c415af_story-tts-69eaea6fb5fee93883c415ae.mp3",
          "_audioDuration": 5.088
        },
        {
          "character_id": "69eae7acb5fee93883c40a27",
          "text": "Pai, chegou aviso da colônia. 'Pescadores com RGP vencido não recebem o seguro-defeso este ano. Prazo de renovação: 10 dias.",
          "position": 1,
          "_ttsGenerating": false,
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d4de6650e26dad215b2/story_audio/69eaea7eb5fee93883c415b1_story-tts-69eaea7eb5fee93883c415b0.mp3",
          "_audioDuration": 8.088
        },
        {
          "character_id": "pa1_c1",
          "text": "Quanto tempo faz que não renovo esse negócio?",
          "position": 2,
          "_ttsGenerating": false,
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d4de6650e26dad215b2/story_audio/69eaea8db5fee93883c415b3_story-tts-69eaea8db5fee93883c415b2.mp3",
          "_audioDuration": 2.976
        },
        {
          "character_id": "69eae7acb5fee93883c40a27",
          "text": "Dois anos, pai. Dois anos.",
          "position": 3,
          "_ttsGenerating": false,
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d4de6650e26dad215b2/story_audio/69eaea9ab5fee93883c415b5_story-tts-69eaea9ab5fee93883c415b4.mp3",
