      "type": "scene",
      "transition": "fade",
      "next_scene_id": "mc1_s3",
      "dialogues": [
        {
          "position": 1,
          "text": "Uma mensagem de uma rede de farmácias do Piauí mudou os planos da família Costa.",
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d24e6650e26dad21537/story_audio/69ea95b4b5fee93883c356fc_story-tts-69ea95b4b5fee93883c356fb.mp3",
          "voice_profile": "nova",
          "_ttsGenerating": false,
          "_audioDuration": 5.136
        },
        {
          "position": 2,
          "character_id": "mc1_c1",
          "text": "Pai, uma rede de farmácias quer comprar mel artesanal local. Preço três vezes maior que o mercado informal. Mas eles pedem inspeção sanitária.",
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d24e6650e26dad21537/story_audio/69ea95b9b5fee93883c356fe_story-tts-69ea95b9b5fee93883c356fd.mp3",
          "voice_profile": "alloy",
          "_ttsGenerating": false,
          "_audioDuration": 8.976
        },
        {
          "position": 3,
          "character_id": "mc1_c2",
          "text": "Inspeção. Nunca precisamos de papel pra vender até hoje.",
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d24e6650e26dad21537/story_audio/69ea95bdb5fee93883c35700_story-tts-69ea95bdb5fee93883c356ff.mp3",
          "voice_profile": "onyx",
          "_ttsGenerating": false,
          "_audioDuration": 3.552
