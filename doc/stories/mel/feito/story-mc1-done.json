        {
          "position": 2,
          "character_id": "mc1_c1",
          "text": "A farmácia pede SIE mínimo. A gente pode começar pelo SIM?",
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d24e6650e26dad21537/story_audio/69ea9614b5fee93883c3571d_story-tts-69ea9614b5fee93883c3571c.mp3",
