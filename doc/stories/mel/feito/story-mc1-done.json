        {
          "position": 2,
          "character_id": "mc1_c2",
          "text": "Com SIE, o mel entra nas prateleiras legalmente — e com preço justo.",
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d24e6650e26dad21537/story_audio/69ea95ebb5fee93883c3570f_story-tts-69ea95ebb5fee93883c3570e.mp3",
