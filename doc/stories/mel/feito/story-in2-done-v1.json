      "title": "Entendendo a Fumaça",
      "type": "scene",
      "transition": "fade",
      "dialogues": [
        {
          "position": 0,
          "character_id": "in2_c1",
          "text": "A fumaça não mata nada — ela imita um incêndio florestal. As abelhas enchem o papo de mel, preparando pra fugir.",
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d24e6650e26dad21537/story_audio/69ea4931b5fee93883c2e5f2_story-tts-69ea4931b5fee93883c2e5f1.mp3",
          "_ttsGenerating": false,
          "_audioDuration": 6.912
        },
        {
          "position": 1,
          "character_id": "in2_c1",
          "text": "Com o papo cheio, elas ficam dóceis e é difícil usar o ferrão. É o instinto natural delas trabalhando a nosso favor.",
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d24e6650e26dad21537/story_audio/69ea4937b5fee93883c2e5fd_story-tts-69ea4937b5fee93883c2e5fc.mp3",
