        {
          "position": 0,
          "character_id": "in2_c1",
          "text": "Tirar tudo enfraquece a colmeia — especialmente na entressafra, quando as flores são poucas. Uma colmeia faminta pode ser abandonada pela rainha.",
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d24e6650e26dad21537/story_audio/69ea4a19b5fee93883c2e65c_story-tts-69ea4a19b5fee93883c2e65b.mp3",
