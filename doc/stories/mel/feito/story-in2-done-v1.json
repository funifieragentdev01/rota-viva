      "type": "decision",
      "transition": "fade",
      "dialogues": [
        {
          "position": 0,
          "character_id": "in2_c1",
          "text": "Antes de colher, precisamos verificar se o mel está no ponto. Mel tirado cedo tem muita água — fermenta em dias e perde tudo.",
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d24e6650e26dad21537/story_audio/69ea4962b5fee93883c2e620_story-tts-69ea4962b5fee93883c2e61f.mp3",
          "_ttsGenerating": false,
          "_audioDuration": 7.776
        },
        {
          "position": 1,
          "character_id": "in2_c3",
          "text": "Como eu sei que está pronto, pai?",
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d24e6650e26dad21537/story_audio/69ea4966b5fee93883c2e622_story-tts-69ea4966b5fee93883c2e621.mp3",
