        },
        {
          "position": 2,
          "character_id": "mb2_c2",
          "text": "Duzentas crianças vão comer nosso mel na merenda essa semana. Nada de corte.",
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d24e6650e26dad21537/story_audio/69ea96f1b5fee93883c36194_story-tts-69ea96f1b5fee93883c36193.mp3",
