          "_ttsGenerating": false,
          "_audioDuration": 8.112
        },
        {
          "position": 2,
          "text": "Seu Zé respira fundo. Essa é a hora que ele esperava.",
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d24e6650e26dad21537/story_audio/69e80b4bb5fee93883beded5_story-tts-69e80b4bb5fee93883beded4.mp3",
