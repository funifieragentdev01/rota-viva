      "dialogues": [
        {
          "position": 0,
          "character_id": "ma1_c2",
          "text": "Com o seu CAF, o senhor pode acessar o PRONAF. Muito bem!",
          "audio_url": "https://s3.amazonaws.com/funifier/games/69c58d24e6650e26dad21537/story_audio/69e7e593b5fee93883be8f34_story-tts-69e7e593b5fee93883be8f33.mp3",
          "_audioDuration": 2.736
        },
        {
          "position": 1,
          "character_id": "ma1_c2",
          "text": "Temos duas modalidades: o custeio, para cobrir os gastos do apiário no ano, e o investimento, para comprar equipamentos e expandir.",
