      "transition": "fade",
      "dialogues": [
        {
          "position": 0,
          "character_id": "ma2_c3",
          "text": "Nota Fiscal de Produtor Rural, gratuita — emitida pela Sefaz-PI com o CPF e o CAF de vocês. Eu ajudo a tirar ainda hoje.",
